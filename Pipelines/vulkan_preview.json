{
  "name": "VulkanForwardPreview",
  "resources": [
    {
      "name": "skyOutput",
      "type": "texture",
      "format": "RGBA16Float",
      "size": "screen"
    },
    {
      "name": "forwardColor",
      "type": "texture",
      "format": "RGBA16Float",
      "size": "screen"
    },
    {
      "name": "depth",
      "type": "texture",
      "format": "Depth32Float",
      "size": "screen"
    },
    {
      "name": "exposureLut",
      "type": "texture",
      "format": "R32Float",
      "size": "1x1"
    }
  ],
  "passes": [
    {
      "name": "Sky Pass",
      "type": "SkyPass",
      "inputs": [],
      "outputs": [
        "skyOutput"
      ],
      "enabled": true,
      "sideEffect": false,
      "config": {
        "exposure": 10.0
      }
    },
    {
      "name": "Forward Pass",
      "type": "ForwardPass",
      "inputs": [
        "skyOutput"
      ],
      "outputs": [
        "forwardColor",
        "depth"
      ],
      "enabled": true,
      "sideEffect": false,
      "config": {}
    },
    {
      "name": "Auto Exposure",
      "type": "AutoExposurePass",
      "inputs": [
        "forwardColor"
      ],
      "outputs": [
        "exposureLut"
      ],
      "enabled": true,
      "sideEffect": false,
      "config": {}
    },
    {
      "name": "Tonemap",
      "type": "TonemapPass",
      "inputs": [
        "forwardColor",
        "exposureLut"
      ],
      "outputs": [
        "$backbuffer"
      ],
      "enabled": true,
      "sideEffect": false,
      "config": {
        "method": "Clip",
        "exposure": 1.0,
        "contrast": 1.0,
        "brightness": 1.0,
        "saturation": 1.0,
        "vignette": 0.0,
        "dither": false,
        "autoExposure": true
      }
    },
    {
      "name": "ImGui Overlay",
      "type": "ImGuiOverlayPass",
      "inputs": [
        "depth"
      ],
      "outputs": [
        "$backbuffer"
      ],
      "enabled": true,
      "sideEffect": false,
      "config": {}
    }
  ]
}
